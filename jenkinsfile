
pipeline {
    agent any

    tools {
        maven 'maven'
        nodejs 'node'
    }

    stages {

        stage('Clean up') {
            steps {
                deleteDir()
            }
        }

        stage('Clone repo') {
            steps {
                bat 'git clone https://github.com/ammarzarouki8/deploy-app-spring-angular.git'
            }
        }

        stage('Generate frontend image') {
            steps {
                dir('Dep/angular-app') {

                    withCredentials([usernamePassword(
                        credentialsId: 'docker-hub-creds',
                        usernameVariable: 'DOCKER_USER',
                        passwordVariable: 'DOCKER_PASS'
                    )]) {

                        bat 'echo %DOCKER_PASS% | docker login -u %DOCKER_USER% --password-stdin'

                        bat 'docker build -t ammarzarouki8/myapp-frontend . --no-cache'

                        bat 'docker push ammarzarouki8/myapp-frontend'
                    }
                }
            }
        }


        stage('Generate backend image') {
            steps {
                dir('Dep/springboot/app') {

                    withCredentials([usernamePassword(
                        credentialsId: 'docker-hub-creds',
                        usernameVariable: 'DOCKER_USER',
                        passwordVariable: 'DOCKER_PASS'
                    )]) {

                        bat 'echo %DOCKER_PASS% | docker login -u %DOCKER_USER% --password-stdin'

                        bat 'set "MAVEN_USER_HOME=C:\\Jenkins\\.m2" && mvnw.cmd clean install'

                        bat 'docker build -t ammarzarouki8/myapp-backend . --no-cache'

                        bat 'docker push ammarzarouki8/myapp-backend'
                    }
                }
            }
        }

        stage('Deploy') {
            steps {
                dir("Dep") {
                  bat 'docker compose up -d'
                }
            }
        }

    }
}
